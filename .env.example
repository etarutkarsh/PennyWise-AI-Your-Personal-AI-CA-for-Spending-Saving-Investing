# Copy this file to .env and adjust as needed, then run:
#   docker compose up --build
# docker compose automatically reads a .env file in this directory.

DB_USERNAME=pennywise
DB_PASSWORD=pennywise

# Generate your own for anything beyond local testing, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-this-secret-in-production-min-256-bits-long

# Optional - only needed once the AI chat/insights features call OpenAI.
OPENAI_API_KEY=
